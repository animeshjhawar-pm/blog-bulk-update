{
  "name": "blog-image-regen",
  "version": "0.1.0",
  "private": true,
  "description": "Single-client batch blog-image regenerator. Reads published clusters from gw_stormbreaker, builds prompts via Portkey, generates images via Replicate (or fal.ai), writes a CSV.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "inspect-page-info": "tsx src/cli.ts inspect-page-info",
    "extract-token": "tsx src/cli.ts extract-token",
    "regen": "tsx src/cli.ts regen",
    "upload": "tsx src/cli.ts upload",
    "repoint": "tsx src/cli.ts repoint",
    "revert": "tsx src/cli.ts revert",
    "web": "tsx src/cli.ts web",
    "start": "tsx src/cli.ts web",
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1044.0",
    "@fal-ai/client": "^1.6.4",
    "@types/archiver": "^6.0.4",
    "archiver": "^7.0.1",
    "axios": "^1.7.7",
    "commander": "^12.1.0",
    "csv-parse": "^6.2.1",
    "csv-stringify": "^6.5.2",
    "dotenv": "^16.4.5",
    "p-limit": "^6.2.0",
    "pg": "^8.13.1",
    "replicate": "^1.0.1",
    "sharp": "^0.34.5",
    "tsx": "^4.19.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.10",
    "typescript": "^5.7.2"
  }
}
