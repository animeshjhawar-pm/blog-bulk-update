# AWS — required for the inline-image fetch (Shape A markdown reads from
# s3://gw-stormbreaker/page_data/...) AND for Apply-to-S3 PUTs into
# s3://gw-content-store/.... Without these, the workspace will only show
# cover + thumbnail rows; inline infographic / internal / external rows
# stay hidden and Apply-to-S3 fails.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=gw-stormbreaker
S3_CONTENT_BUCKET=gw-content-store
